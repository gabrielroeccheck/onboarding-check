{% liquid
  assign block_settings = block.settings
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif
%}

{% if product != blank %}
  {% render 'product-buy-together', block_settings: block_settings, block: block %}
{% endif %}

{% stylesheet %}
  .product-buy-together {
    display: block;
  }

  .product-buy-together__surface {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md, 1.25rem);
    padding: clamp(1rem, 3vw, 1.35rem);
    border-radius: max(12px, var(--border-radius, 8px));
    background: rgb(var(--color-foreground-rgb) / 0.035);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    box-shadow: 0 1px 0 rgb(var(--color-foreground-rgb) / 0.04);
  }

  .product-buy-together__header {
    padding-block-end: 0.25rem;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
  }

  .product-buy-together__heading {
    margin: 0;
    font-family: var(--font-h5--family);
    font-style: var(--font-h5--style);
    font-weight: var(--font-h5--weight);
    font-size: var(--font-h5--size);
    line-height: var(--font-h5--line-height);
    letter-spacing: var(--font-h5--letter-spacing);
    text-transform: var(--font-h5--case);
    color: var(--color-foreground);
  }

  .product-buy-together__body {
    display: flex;
    align-items: stretch;
    gap: var(--gap-md, 1rem);
    min-width: 0;
  }

  .product-buy-together__thumb-link {
    flex-shrink: 0;
    align-self: flex-start;
    border-radius: calc(var(--product-card-corner-radius, 8px) + 2px);
    overflow: hidden;
    background: var(--color-background);
    box-shadow:
      0 0 0 1px rgb(var(--color-foreground-rgb) / 0.06),
      0 4px 14px rgb(var(--color-foreground-rgb) / 0.06);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .product-buy-together__thumb-link:hover {
    box-shadow:
      0 0 0 1px rgb(var(--color-foreground-rgb) / 0.1),
      0 6px 20px rgb(var(--color-foreground-rgb) / 0.08);
    transform: translateY(-1px);
  }

  .product-buy-together__thumb {
    display: block;
    width: 5.5rem;
    height: 5.5rem;
  }

  @media screen and (min-width: 750px) {
    .product-buy-together__thumb {
      width: 6rem;
      height: 6rem;
    }
  }

  .product-buy-together__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-buy-together__image--placeholder {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 5.5rem;
    background: linear-gradient(
      135deg,
      rgb(var(--color-foreground-rgb) / 0.06) 0%,
      rgb(var(--color-foreground-rgb) / 0.03) 100%
    );
  }

  .product-buy-together__meta {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
    min-width: 0;
    flex: 1;
  }

  .product-buy-together__kicker {
    margin: 0;
    font-size: max(0.7rem, 0.6875rem);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    line-height: 1.2;
  }

  .product-buy-together__name {
    margin: 0;
    font-family: var(--font-paragraph--family);
    font-size: var(--font-paragraph--size, 1rem);
    font-weight: 600;
    line-height: 1.35;
    text-decoration: none;
    color: rgb(var(--color-foreground-rgb));
    text-wrap: pretty;
    transition: color 0.15s ease, opacity 0.15s ease;
  }

  .product-buy-together__name:hover {
    color: rgb(var(--color-foreground-rgb) / 0.75);
  }

  .product-buy-together__price {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.5rem;
    font-size: 0.9375rem;
    font-variant-numeric: tabular-nums;
  }

  .product-buy-together__current {
    font-weight: 600;
    color: rgb(var(--color-foreground-rgb));
  }

  .product-buy-together__compare {
    font-size: 0.875em;
    font-weight: 500;
    color: rgb(var(--color-foreground-rgb) / 0.45);
    text-decoration-thickness: 1px;
  }

  .product-buy-together__footer {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .product-buy-together__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    min-height: 2.875rem;
    padding-block: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  .product-buy-together__submit:hover:not(:disabled) {
    transform: translateY(-1px);
  }

  .product-buy-together__submit:active:not(:disabled) {
    transform: translateY(0);
  }

  .product-buy-together__btn-icon {
    flex-shrink: 0;
    width: 1.125rem;
    height: 1.125rem;
  }

  .product-buy-together__btn-icon svg {
    width: 100%;
    height: 100%;
  }

  .product-buy-together__error {
    margin: 0;
    padding: 0.5rem 0.65rem;
    font-size: 0.875rem;
    line-height: 1.4;
    color: rgb(var(--color-error, 180 50 50));
    text-align: center;
    border-radius: var(--border-radius, 8px);
    background: rgb(var(--color-error, 180 50 50) / 0.08);
  }

  .product-buy-together__error.hidden {
    display: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_buy_together",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.buy_together_heading",
      "default": "Leve junto e economize"
    },
    {
      "type": "header",
      "content": "t:content.buy_together_metafield_help"
    },
    {
      "type": "paragraph",
      "content": "t:content.buy_together_metafield_body"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
