{%- assign valor_minimo = settings.free_shipping_threshold | default: 200 -%}
{%- assign valor_total_carrinho = cart.total_price | times: 0.01 | round: 2 -%}
{%- assign progress = valor_total_carrinho | times: 100 | divided_by: valor_minimo | round: 2 -%}

<div class="container-shipping-bar">
  <div class="shipping-bar">
    <div class="shipping-bar__fill"></div>
  </div>

  {%- if valor_total_carrinho >= valor_minimo -%}
    <p class="shipping-bar__text">{{ 'shipping_bar.free_shipping' | t }}</p>
  {%- else -%}
    {%- assign valor_restante = valor_minimo | minus: valor_total_carrinho -%}
    {%- assign valor_restante_centavos = valor_restante | times: 100 | money -%}

    <p class="shipping-bar__text">{{ 'shipping_bar.remaining' | t: value: valor_restante_centavos}}</p>
  {%- endif -%}
</div>

<style>
  .container-shipping-bar {
    padding: 10px 0;
  }

  .shipping-bar {
    position: relative;
    width: 100%;
    height: 5px;
    background-color: #f3f3f3;
    border-radius: 50px;
    margin-bottom: 10px;
    overflow: hidden;
  }

  .shipping-bar__fill {
    width: {{ progress }}%;
    max-width: 100%;
    height: 100%;
    background-color: #000;
    transition: width 0.5s ease-in-out;
    display: block !important;
  }

  .shipping-bar__text {
    text-align: center;
    color: #000;
    font-size: 14px;
    margin-top: 8px;
  }
</style>
